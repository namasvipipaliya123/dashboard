{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build" },
    { "src": "backend/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "backend/index.js" },
    { "src": "/(.*)", "dest": "frontend/build/$1" }
  ],

  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
  