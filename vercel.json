{
  "version": 2,
  "builds": [
    {
      "src": "backend/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "Frontend/build" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/build/$1"
    }
  ]
}
